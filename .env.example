# ============================================================
# Configuration environnement - Huduma
# ============================================================
# Copier ce fichier en .env et adapter les valeurs.

# --- Core ---
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DEBUG=True

# --- Hotes autorises (separe par virgules) ---
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Base de donnees ---
# En dev : sqlite (par defaut). Pour PostgreSQL :
# DATABASE_URL=postgres://huduma:huduma@localhost:5432/huduma
DATABASE_ENGINE=sqlite
DATABASE_NAME=db.sqlite3
# DATABASE_ENGINE=postgres
# DATABASE_NAME=huduma
# DATABASE_USER=huduma
# DATABASE_PASSWORD=huduma
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
